# ──────────────────────────────────────────────
# AI Talent Lab – Environment Variables
# Copy to .env and fill in your values
# ──────────────────────────────────────────────

# ── App ───────────────────────────────────────
# Application version string
APP_VERSION="1.0.0"

# Frontend URL for CORS whitelist and redirect URLs
FRONTEND_URL="http://localhost:5173"

# Base URL for magic links sent in emails (apply, panel feedback, password reset)
MAGIC_LINK_BASE_URL="http://localhost:5173"

# ── Database (REQUIRED) ──────────────────────
# PostgreSQL connection string. Docker Compose default shown below.
DATABASE_URL="postgresql://talentlab:talentlab@localhost:5432/talentlab_dev"

# ── Redis (REQUIRED for Celery background tasks) ──
REDIS_URL="redis://localhost:6379/0"

# ── Auth (REQUIRED — app fails without this) ──
# Must be a strong random string, minimum 32 characters.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET="CHANGE_ME_generate_with_secrets_token_urlsafe_48"

# JWT token expiry in hours (default: 24)
JWT_EXPIRY_HOURS=24

# ── LLM Provider ─────────────────────────────
# Which LLM provider to use: "groq" | "openai" | "gemini"
LLM_PROVIDER="groq"

# Groq API key (required if LLM_PROVIDER=groq)
GROQ_API_KEY="your_groq_api_key_here"

# OpenAI API key (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=""

# Google Gemini API key (required if LLM_PROVIDER=gemini)
GEMINI_API_KEY=""

# ── Web Search ────────────────────────────────
# Tavily API key for market research step in JD generation
TAVILY_API_KEY="your_tavily_api_key_here"

# ── Email Provider ────────────────────────────
# Which email provider to use: "simulation" | "resend" | "smtp"
# "simulation" logs emails to console (dev/demo)
EMAIL_PROVIDER="simulation"

# Resend API key (required if EMAIL_PROVIDER=resend)
RESEND_API_KEY=""

# SMTP settings (required if EMAIL_PROVIDER=smtp)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""

# From address and name for outgoing emails
FROM_EMAIL="hiring@aitalentlab.com"
FROM_NAME="AI Talent Lab"

# ── Candidate Sourcing ────────────────────────
# Candidate source adapter: "simulation" (MVP) | "linkedin" | "naukri"
CANDIDATE_SOURCE_ADAPTER="simulation"

# ── Magic Link Expiry ────────────────────────
# Apply link expiry in hours (default: 72 = 3 days)
APPLY_LINK_EXPIRY_HOURS=72

# Panel feedback link expiry in hours (default: 168 = 7 days)
PANEL_LINK_EXPIRY_HOURS=168

# Password reset link expiry in hours (default: 24)
RESET_LINK_EXPIRY_HOURS=24

# ── Encryption ────────────────────────────────
# AES-256 key for encrypting PII (CTC fields). Required in production.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ENCRYPTION_KEY=""

# ── Celery ────────────────────────────────────
# Celery broker URL. Defaults to REDIS_URL if empty.
CELERY_BROKER_URL=""
