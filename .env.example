# ──────────────────────────────────────────────
# AI Talent Lab – Environment Variables
# ──────────────────────────────────────────────

# Active LLM Provider: "groq" | "openai" | "gemini"
LLM_PROVIDER="groq"

# ── Groq ──────────────────────────────────────
GROQ_API_KEY="your_api_key_here"
GROQ_MODEL="llama-3.1-8b-instant"

# ── OpenAI ────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# ── Google Gemini ─────────────────────────────
GEMINI_API_KEY="your_api_key_here"
GEMINI_MODEL="gemini-3-pro-preview"

# ── App ───────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:5173
DEBUG=true

# ── User (mock for phase-1) ───────────────────
USER_NAME="Elavala"
USER_EMAIL="elavala@aitalentlab.com"

# ── Web Search ────────────────────────────────
# Get your free key at https://tavily.com
TAVILY_API_KEY="your_api_key_here"

# ── Database ──────────────────────────────────
ORG_NAME="AI Talent Lab"
ORG_SEGMENT="AI Recruitment Technology"
ORG_SIZE="startup"

# ── Embedding Model (for ChromaDB vector store) ──
# Default uses chromadb's built-in ONNX model.
# For production, set to a Sentence Transformer model name:
# EMBEDDING_MODEL="all-MiniLM-L6-v2"
EMBEDDING_MODEL="default"

